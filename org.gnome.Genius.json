{
    "app-id": "org.gnome.Genius",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "gnome-genius",
    "rename-desktop-file": "gnome-genius.desktop",
    "rename-icon": "gnome-genius",
    "finish-args": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--own-name=org.gnome.genius",
        "--persist=.genius",
        "--persist=.gnome2"
    ],
    "cleanup": [
        "/include",
        "/lib/girepository-1.0",
        "/lib/pkgconfig",
        "/man",
        "/share/aclocal",
        "/share/doc",
        "/share/gir-1.0",
        "/share/glade",
        "/share/pkgconfig",
        "/share/gtk-doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        "shared-modules/intltool/intltool-0.51.json",
        {
            "name": "libgedit-amtk",
            "buildsystem": "meson",
            "config-opts": [
                "-Dgtk_doc=false",
                "-Dgobject_introspection=false",
                "-Dtests=false"
            ],
            "sources": [
                {
                    "x-checker-data": {
                        "type": "git"
                    },
                    "type": "git",
                    "url": "https://gitlab.gnome.org/World/gedit/libgedit-amtk.git",
                    "tag": "5.9.2"
                }
            ]
        },
        {
            "name": "gtksourceview",
            "buildsystem": "meson",
            "config-opts": [
                "-Dinstall_tests=false",
                "-Dgtk_doc=false",
                "-Dvapi=false"
            ],
            "sources": [
                {
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "gtksourceview",
                        "//": "gtksourceview5 is the GTK 4 version",
                        "versions": {
                            "<": "4.99"
                        }
                    },
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/gtksourceview/4.8/gtksourceview-4.8.4.tar.xz",
                    "sha256": "7ec9d18fb283d1f84a3a3eff3b7a72b09a10c9c006597b3fbabbb5958420a87d"
                }
            ]
        },
        {
            "name": "vte",
            "buildsystem": "meson",
            "config-opts": [
                "-Ddocs=false",
                "-Dvapi=false",
                "-Dgtk4=false"
            ],
            "sources": [
                {
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "vte"
                    },
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/vte/0.82/vte-0.82.2.tar.xz",
                    "sha256": "e1295aafc4682b3b550f1235dc2679baa0f71570d8ed543c001c1283d530be91"
                }
            ]
        },
        {
            "name": "genius",
            "sources": [
                {
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 9839,
                        "url-template": "http://ftp.5z.com/pub/genius/genius-$version.tar.xz"
                    },
                    "type": "archive",
                    "url": "http://ftp.5z.com/pub/genius/genius-1.0.27.tar.xz",
                    "sha256": "39098d0054ccc60b4b0ff6ca37276c72eea73806082d4c2e9738a29b7c78b20a"
                },
                {
                    "type": "file",
                    "path": "org.gnome.Genius.appdata.xml"
                }
            ],
            "post-install": [
                "install -Dm644 org.gnome.Genius.appdata.xml /app/share/appdata/org.gnome.Genius.appdata.xml",
                "mv /app/share/mime/packages/genius.xml /app/share/mime/packages/org.gnome.Genius.xml"
            ]
        }
    ]
}
